        <mxCell id="title-text" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="&lt;font style=&quot;font-size:30px;font-weight:bold;color:#FFFFFF;&quot;&gt;Keysight CloudLens vPB — Active-Active HA Architecture&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:14px;color:#B4D8F5;font-weight:600;&quot;&gt;Azure Gateway Load Balancer | Dual vPB Inline Monitoring | Cross-Zone Redundancy&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#89C4F4;&quot;&gt;End-to-End Traffic Flow: Internet → Standard LB → GWLB → vPB VXLAN Hairpin → Web Servers | Mirror → Tool VM&lt;/font&gt;" vertex="1">
