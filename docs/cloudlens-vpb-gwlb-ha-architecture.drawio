        <mxCell id="hairpin-detail" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1B2A4A;strokeColor=#D4AF37;strokeWidth=2;arcSize=8;shadow=1;" value="&lt;font style=&quot;font-size:12px;font-weight:bold;color:#D4AF37;&quot;&gt;VXLAN Hairpin Flow&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#FFFFFF;&quot;&gt;&lt;b style=&quot;color:#27AE60;&quot;&gt;INBOUND PATH:&lt;/b&gt;&lt;br&gt;User → Std LB VIP → GWLB wraps VNI 900/10800&lt;br&gt;→ vPB strips VXLAN → inner dip = LB VIP&lt;br&gt;→ match P1 → egress vxlan2 (VNI 901/10801)&lt;br&gt;→ GWLB unwraps → Std LB DNAT → Web Server&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#3498DB;&quot;&gt;OUTBOUND PATH:&lt;/b&gt;&lt;br&gt;Web Server → GWLB wraps VNI 901/10801&lt;br&gt;→ vPB strips VXLAN → inner sip = LB VIP&lt;br&gt;→ match P2 → egress vxlan1 (VNI 900/10800)&lt;br&gt;→ GWLB unwraps → response to User&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#9B59B6;&quot;&gt;MIRROR (both directions):&lt;/b&gt;&lt;br&gt;Copy of every packet → vxlan3 (VNI 42/4789)&lt;br&gt;→ Tool VM for analysis / tcpdump&lt;/font&gt;" vertex="1">
          <mxGeometry height="310" width="380" x="1340" y="870" as="geometry" />
        </mxCell>
        <mxCell id="dpdk-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F4F8;strokeColor=#CBD5E1;strokeWidth=2;arcSize=8;shadow=1;" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b style=&quot;color:#1B2A4A;&quot;&gt;DPDK Data Plane Architecture&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#374151;&quot;&gt;&lt;b&gt;VF NIC (SR-IOV):&lt;/b&gt; Data plane traffic → DPDK engine&lt;br&gt;&lt;b&gt;Synthetic NIC:&lt;/b&gt; Management + health probes → kernel&lt;br&gt;&lt;b&gt;Key:&lt;/b&gt; GWLB health probes arrive on kernel path,&lt;br&gt;NOT DPDK — requires OS-level HTTP server on port 80&lt;br&gt;&lt;b&gt;packet-dump:&lt;/b&gt; Uses midpdk_ethN mirror interface&lt;/font&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="380" x="1340" y="1200" as="geometry" />
        </mxCell>
        <mxCell id="scale-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#27AE60;strokeWidth=1;arcSize=8;shadow=1;" value="&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b style=&quot;color:#27AE60;&quot;&gt;Scalability&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#374151;&quot;&gt;GWLB backend pool: up to 300 instances&lt;br&gt;Add vPB-3 (Zone 3), vPB-4, vPB-5...&lt;br&gt;Same config per vPB, identical match rules&lt;br&gt;Each gets proportional share of flows&lt;/font&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="380" x="1340" y="1320" as="geometry" />
        </mxCell>
